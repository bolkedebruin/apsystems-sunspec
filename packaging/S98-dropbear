#!/bin/sh
#
# S98-dropbear — start the dropbear SSH server bundled with this package.
# Skipped automatically if the bundled binary doesn't exist (e.g., main
# package without --with-dropbear).

DBEAR=/usr/local/sbin/dropbear
PORT=22

start() {
    [ -x "$DBEAR" ] || { echo "dropbear not installed"; return 0; }
    if pidof dropbear >/dev/null 2>&1; then
        echo "dropbear already running"
        return 0
    fi
    "$DBEAR" -R -E -p "$PORT" >/dev/null 2>&1 &
    echo "dropbear started on :$PORT"
}

stop() {
    if pidof dropbear >/dev/null 2>&1; then
        killall -q dropbear
        echo "dropbear stopped"
    fi
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; sleep 1; start ;;
    *)
        echo "usage: $0 {start|stop|restart}"
        exit 2
        ;;
esac
